---
import { getCollection, render } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"

//function that get generates all static paths for the projects 
export async function getStaticPaths() {
  //get all projects from the collection
  const projects = await getCollection('projects')

  //returns the projects map to a single projecct, with its params and a slug 
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }))
}

//const project with all its props
const {project} = Astro.props
//content render
const {Content} = await render(project)

--- 

<BaseLayout title={project.data.title}>
  <Fragment slot = "hero">
  <article class="max-w-2xl mx-auto py-16 px-4 flex flex-col gap-6">

    <h1 transition:name={`title-${project.id}`}, class="text-4xl font-bold text-zinc-100">{project.data.title}</h1>
    <p class="text-zinc-500 text-sm">{project.data.author}</p>

    <div>
      <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Stack</span>
      <p class="text-zinc-300 mt-1">{project.data.technologies}</p>
    </div>

    <div>
      <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Skills</span>
      <p class="text-zinc-300 mt-1">{project.data.skills}</p>
    </div>

    <div class="text-zinc-400 leading-relaxed">
      <Content />
    </div>

    <a
      href={project.data.link}
      target="_blank"
      rel="noopener noreferrer"
      class="self-start bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
    >
      Ver proyecto
    </a>

  </article>
  </Fragment>
</BaseLayout>