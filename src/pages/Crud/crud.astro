---

import BaseLayout from "../../layouts/BaseLayout.astro"

---

<BaseLayout title="CRUD">
  <section class="max-w-xl mx-auto flex flex-col gap-6 py-16">
    <h1 class="text-4xl font-bold text-zinc-100 tracking-tight">
      Probando  <span class="text-indigo-400">TypeScript</span>
    </h1>

    <h1 class="text-3xl font-bold text-zinc-100">Tasks</h1>

    <form id="form" class="flex gap-2">
      <input
        id="input"
        type="text"
        placeholder="Nueva tarea..."
        class="flex-1 bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-2 text-zinc-100 placeholder:text-zinc-500 focus:outline-none focus:border-indigo-500"
      />
      <button
        type="submit"
        class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
      >
        Añadir
      </button>
    </form>

    <ul id="list" class="flex flex-col gap-2"></ul>

  </section>
</BaseLayout>


<script>
  interface Task {
    id: number
    description: string
    done: boolean
  }

  const tasks: Task[] = []

  const form  = document.getElementById('form')  as HTMLFormElement
  const input = document.getElementById('input') as HTMLInputElement
  const list  = document.getElementById('list')  as HTMLUListElement

  // ── CRUD ────────────────────────────────────────────────

  function addTask(description: string): void {
    const task: Task = { id: Date.now(), description, done: false }
    tasks.push(task)
    list.appendChild(buildTaskElement(task))
  }

  function toggleTask(task: Task, span: HTMLSpanElement): void {
    task.done = !task.done
    span.className = task.done
      ? 'flex-1 text-zinc-400 line-through'
      : 'flex-1 text-zinc-100'
  }

  function deleteTask(task: Task, li: HTMLLIElement): void {
    const index = tasks.findIndex(t => t.id === task.id)
    tasks.splice(index, 1)  
    li.remove()              
  }

  
  function buildCheckbox(task: Task, span: HTMLSpanElement): HTMLInputElement {
    const checkbox = document.createElement('input')
    checkbox.type = 'checkbox'
    checkbox.checked = task.done
    checkbox.className = 'accent-indigo-500 w-4 h-4 cursor-pointer'
    checkbox.addEventListener('change', () => toggleTask(task, span))
    return checkbox
  }

  function buildSpan(task: Task): HTMLSpanElement {
    const span = document.createElement('span')
    span.textContent = task.description
    span.className = 'flex-1 text-zinc-100'
    return span
  }

  function buildDeleteButton(task: Task, li: HTMLLIElement): HTMLButtonElement {
    const btn = document.createElement('button')
    btn.textContent = '✕'
    btn.className = 'text-zinc-500 hover:text-red-400 transition-colors text-sm'
    btn.addEventListener('click', () => deleteTask(task, li))
    return btn
  }

  function buildTaskElement(task: Task): HTMLLIElement {
    const li   = document.createElement('li')
    const span = buildSpan(task)

    li.className = 'flex items-center gap-3 bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3'
    li.appendChild(buildCheckbox(task, span))
    li.appendChild(span)
    li.appendChild(buildDeleteButton(task, li))

    return li
  }


  form.addEventListener('submit', (e) => {
    e.preventDefault()
    const description = input.value.trim()
    if (!description) return
    addTask(description)
    input.value = ''
  })
</script>
