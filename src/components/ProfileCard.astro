---

interface Props {
    name : string,
    stack : string,
    hobbies : string,
    occupation : string,
    gitHub : string,

}

const {name,stack,hobbies,occupation,gitHub}=Astro.props

---

<article class="flex flex-col gap-8 bg-zinc-900 border border-zinc-800 rounded-2xl p-10 w-full max-w-2xl mx-auto hover:border-indigo-500 transition-colors duration-300">

  <div class="flex items-center gap-6">
    <div class="w-24 h-24 rounded-full bg-indigo-600 flex items-center justify-center text-white text-4xl font-bold shrink-0">
      {name.charAt(0)}
    </div>
    <div>
      <h2 class="text-3xl font-bold text-zinc-100">{name}</h2>
      <p class="text-base text-indigo-400 mt-1">{occupation}</p>
    </div>
  </div>

  <div class="flex flex-col gap-4">
    <div>
      <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Stack</span>
      <p class="text-base text-zinc-300 mt-1">{stack}</p>
    </div>
    <div>
      <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Hobbies</span>
      <p class="text-base text-zinc-300 mt-1">{hobbies}</p>
    </div>
  </div>

  <a
    href={gitHub}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center gap-2 text-sm font-medium text-zinc-300 border border-zinc-700 hover:border-indigo-500 hover:text-indigo-400 rounded-lg px-4 py-3 transition-colors duration-200"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
      <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
    </svg>
    GitHub
  </a>

</article>