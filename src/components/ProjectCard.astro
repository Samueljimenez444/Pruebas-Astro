---
/**
 * ProjectCard - Reusable card component to display a project
 * Used in: /pages/AboutMe/projects.astro
 */
interface Props {
  title: string;
  author: string;
  technologies: string;
  skills: string;
  link: string;
  description: string;
}

const { title, author, technologies, skills, link, description } = Astro.props;
---

<article class="flex flex-col gap-4 bg-zinc-900 border border-zinc-800 rounded-2xl p-6 w-full max-w-sm hover:border-indigo-500 transition-colors duration-300">

  <header>
    <h2 class="text-xl font-bold text-zinc-100">{title}</h2>
    <p class="text-sm text-zinc-500 mt-1">{author}</p>
  </header>

  <p class="text-sm text-zinc-400 leading-relaxed flex-1">{description}</p>

  <div class="flex flex-col gap-2">
    <div>
      <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Stack</span>
      <p class="text-sm text-zinc-300 mt-1">{technologies}</p>
    </div>
    <div>
      <span class="text-xs font-semibold text-indigo-400 uppercase tracking-wider">Skills</span>
      <p class="text-sm text-zinc-300 mt-1">{skills}</p>
    </div>
  </div>

  <a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-auto inline-block text-center text-sm font-medium bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg px-4 py-2 transition-colors duration-200"
  >
    Ver proyecto
  </a>

</article>
